# Terraform local working directory
.terraform/

# Terraform state
*.tfstate
*.tfstate.*

# Terraform variable files, often contain secrets
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
plan.out

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Local environment files
.env
.env.*

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS files
.DS_Store